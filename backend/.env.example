# Copy this file to .env and fill in the values

# Flask environment: development | production
FLASK_ENV=development

# Secret key for Flask (change this in production!)
SECRET_KEY=change-me-in-production

# Database URL
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@db:5432/fingerprints_db
# SQLite (local development fallback):
DATABASE_URL=sqlite:///fingerprints.db

# Allowed CORS origins (comma-separated)
# Use * for open access, or restrict to your frontend URL
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Allow raw fingerprint export via /api/fingerprints/<id>/raw and include_raw=true
# Set to true ONLY in controlled research environments
ALLOW_RAW_EXPORT=false
